<FindBugsFilter
        xmlns="https://github.com/spotbugs/filter/4.8.4"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://github.com/spotbugs/filter/4.8.4 https://raw.githubusercontent.com/spotbugs/spotbugs/4.9.8/spotbugs/etc/findbugsfilter.xsd">
    <!-- no groovy files -->
    <Match>
        <Source name="~.*\.groovy"/>
    </Match>

    <!-- no generated files if we care for a class retention annotation being present that can be checked -->
    <Match>
        <Annotation name="com.facebook.litho.annotations.Generated"/>
    </Match>

    <Match>
        <!-- just ensures bean initialization at startup for subclasses -->
        <And>
            <Class name="net.kautler.command.api.CommandHandler"/>
            <Method name="ensureInitializationAtStartup" params="java.lang.Object" returns="void"/>
        </And>
        <Bug pattern="ACEM_ABSTRACT_CLASS_EMPTY_METHODS"/>
    </Match>

    <!-- we really need a newline character there -->
    <Match>
        <Class name="net.kautler.command.parameter.parser.BaseParameterParser"/>
        <Method name="parse" params="net.kautler.command.api.CommandContext, java.util.function.BiFunction" returns="net.kautler.command.api.parameter.Parameters"/>
        <Method name="format" params="java.lang.String, java.lang.Object[]" returns="java.lang.String" role="METHOD_CALLED"/>
        <Bug pattern="VA_FORMAT_STRING_USES_NEWLINE"/>
    </Match>

    <Match>
        <Or>
            <!-- the static string should be clear enough in these cases -->
            <And>
                <Or>
                    <Class name="net.kautler.command.api.restriction.javacord.ChannelJavacord$Parameters"/>
                    <Class name="net.kautler.command.api.restriction.javacord.RoleJavacord$Parameters"/>
                    <Class name="net.kautler.command.api.restriction.javacord.ServerJavacord$Parameters"/>
                    <Class name="net.kautler.command.api.restriction.javacord.UserJavacord$Parameters"/>
                    <Class name="net.kautler.command.api.restriction.javacord.slash.ChannelJavacordSlash$Parameters"/>
                    <Class name="net.kautler.command.api.restriction.javacord.slash.RoleJavacordSlash$Parameters"/>
                    <Class name="net.kautler.command.api.restriction.javacord.slash.ServerJavacordSlash$Parameters"/>
                    <Class name="net.kautler.command.api.restriction.javacord.slash.UserJavacordSlash$Parameters"/>
                    <Class name="net.kautler.command.api.restriction.jda.ChannelJda$Parameters"/>
                    <Class name="net.kautler.command.api.restriction.jda.GuildJda$Parameters"/>
                    <Class name="net.kautler.command.api.restriction.jda.RoleJda$Parameters"/>
                    <Class name="net.kautler.command.api.restriction.jda.UserJda$Parameters"/>
                </Or>
                <Or>
                    <Method name="ensureAtLeastOneConditionIsSet" params="" returns="void"/>
                    <Method name="ensureCaseSensitiveIfNameIsNotSet" params="" returns="void"/>
                </Or>
            </And>
            <!-- the cause is enough context here -->
            <And>
                <Class name="net.kautler.test.pitest.SpockTestUnitFinder"/>
                <Method name="findTestUnits" params="java.lang.Class, org.pitest.testapi.TestUnitExecutionListener" returns="java.util.List"/>
            </And>
        </Or>
        <Bug pattern="WEM_WEAK_EXCEPTION_MESSAGING"/>
    </Match>

    <Match>
        <Or>
            <!-- acceptable risk for this double-checked locking code -->
            <And>
                <Class name="net.kautler.command.util.lazy.LazyReference"/>
                <Method name="get" params="java.util.function.Supplier" returns="java.lang.Object"/>
                <Method name="lock" params="" returns="void" role="METHOD_CALLED"/>
            </And>
            <!-- this is in tests infrastructure code and intentionally waiting forever -->
            <And>
                <Class name="net.kautler.test.pitest.SpockTestUnitFinder$TestIdentifierListener"/>
                <Method name="lock" params="org.junit.platform.launcher.TestIdentifier" returns="void"/>
                <Method name="lock" params="" returns="void" role="METHOD_CALLED"/>
            </And>
        </Or>
        <Bug pattern="MDM_WAIT_WITHOUT_TIMEOUT"/>
    </Match>

    <Match>
        <Or>
            <!-- false positive, these are for downstream consumers -->
            <And>
                <Class name="net.kautler.command.api.CommandContext"/>
                <Or>
                    <Method name="getAdditionalData" params="java.lang.String" returns="java.util.Optional"/>
                    <Method name="getAdditionalData" params="java.lang.String, java.lang.Object" returns="java.lang.Object"/>
                </Or>
            </And>
        </Or>
        <Bug pattern="OPM_OVERLY_PERMISSIVE_METHOD"/>
    </Match>

    <!-- false-positive, the found state is just an internal performance cache -->
    <Match>
        <Class name="net.kautler.command.api.restriction.jda.BotOwnerJda"/>
        <Bug pattern="IMC_IMMATURE_CLASS_NO_TOSTRING"/>
    </Match>

    <!-- false positive -->
    <Match>
        <Class name="net.kautler.command.handler.CommandHandlerJda"/>
        <Method name="addListener" params="" returns="void"/>
        <Bug pattern="CRLF_INJECTION_LOGS"/>
    </Match>

    <!-- the field gets set in an @Inject setter, so should never be null at usage time -->
    <Match>
        <Class name="net.kautler.command.parameter.parser.TypedParameterParser"/>
        <Field name="parameterConverterTypeLiteralsByMessageType"/>
        <Bug pattern="UWF_FIELD_NOT_INITIALIZED_IN_CONSTRUCTOR"/>
    </Match>

    <!-- the nonKilledSurvivors field is constantly changing, it is not part of the instance identity -->
    <Match>
        <Class name="net.kautler.test.pitest.NonkilledSurvivorDetector"/>
        <Bug pattern="IMC_IMMATURE_CLASS_NO_EQUALS"/>
    </Match>

    <!-- the decision is up to the user of the library, according methods have a warning -->
    <Match>
        <Or>
            <And>
                <Class name="net.kautler.command.api.restriction.javacord.ChannelJavacord"/>
                <Method name="lambda$allowCommandByChannelName$0" params="java.lang.String" returns="java.lang.Boolean"/>
            </And>
            <And>
                <Class name="net.kautler.command.api.restriction.javacord.RoleJavacord"/>
                <Method name="lambda$null$9" params="java.lang.String" returns="boolean"/>
            </And>
            <And>
                <Class name="net.kautler.command.api.restriction.javacord.ServerJavacord"/>
                <Method name="lambda$allowCommandByServerName$1" params="java.lang.String" returns="java.lang.Boolean"/>
            </And>
            <And>
                <Class name="net.kautler.command.api.restriction.javacord.UserJavacord"/>
                <Method name="lambda$allowCommandByUserName$1" params="java.lang.String" returns="java.lang.Boolean"/>
            </And>
            <And>
                <Class name="net.kautler.command.api.restriction.javacord.slash.ChannelJavacordSlash"/>
                <Method name="lambda$allowCommandByChannelName$0" params="java.lang.String" returns="java.lang.Boolean"/>
            </And>
            <And>
                <Class name="net.kautler.command.api.restriction.javacord.slash.RoleJavacordSlash"/>
                <Method name="lambda$null$9" params="java.lang.String" returns="boolean"/>
            </And>
            <And>
                <Class name="net.kautler.command.api.restriction.javacord.slash.ServerJavacordSlash"/>
                <Method name="lambda$allowCommandByServerName$1" params="java.lang.String" returns="java.lang.Boolean"/>
            </And>
            <And>
                <Class name="net.kautler.command.api.restriction.javacord.slash.UserJavacordSlash"/>
                <Method name="allowCommandByUserName" params="org.javacord.api.interaction.SlashCommandInteraction" returns="boolean"/>
            </And>
            <And>
                <Class name="net.kautler.command.api.restriction.jda.ChannelJda"/>
                <Method name="allowCommandByChannelName" params="net.dv8tion.jda.api.entities.Message" returns="boolean"/>
            </And>
            <And>
                <Class name="net.kautler.command.api.restriction.jda.GuildJda"/>
                <Method name="lambda$allowCommandByGuildName$3" params="java.lang.String" returns="java.lang.Boolean"/>
            </And>
            <And>
                <Class name="net.kautler.command.api.restriction.jda.RoleJda"/>
                <Method name="lambda$null$8" params="java.lang.String" returns="boolean"/>
            </And>
            <And>
                <Class name="net.kautler.command.api.restriction.jda.UserJda"/>
                <Method name="lambda$allowCommandByUserName$1" params="java.lang.String" returns="java.lang.Boolean"/>
            </And>
        </Or>
        <Bug pattern="IMPROPER_UNICODE"/>
    </Match>

    <!-- false-positive as TestIdentifier is effectively immutable -->
    <Match>
        <Class name="net.kautler.test.pitest.SpockTestUnit"/>
        <Method name="&lt;init&gt;" params="java.lang.Class, org.junit.platform.launcher.TestIdentifier" returns="void"/>
        <Field name="testIdentifier"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!-- the command context is meant to be altered to transport state, so this is perfectly fine here -->
    <Match>
        <Class name="net.kautler.command.api.event.CommandEvent"/>
        <Method name="getCommandContext" params="" returns="net.kautler.command.api.CommandContext"/>
        <Field name="commandContext"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>

    <!-- the method is allowed to throw any exception, the caller will rethrow all cases as a runtime exception -->
    <Match>
        <Or>
            <And>
                <Class name="net.kautler.command.api.parameter.ParameterConverter"/>
                <Method name="convert" params="java.lang.String, java.lang.String, net.kautler.command.api.CommandContext" returns="java.lang.Object"/>
            </And>
            <And>
                <Class name="net.kautler.command.parameter.converter.javacord.UserMentionConverterJavacord"/>
                <Method name="convert" params="java.lang.String, java.lang.String, net.kautler.command.api.CommandContext" returns="org.javacord.api.entity.user.User"/>
            </And>
        </Or>
        <Bug pattern="THROWS_METHOD_THROWS_CLAUSE_BASIC_EXCEPTION"/>
    </Match>
</FindBugsFilter>
