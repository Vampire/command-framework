<Configuration name="Command Framework Tests" status="INFO" strict="true">
    <Appenders>
        <Console name="Console Appender" follow="true">
            <PatternLayout>
                <Pattern><![CDATA[%highlight{%d <%-5p> <%-35.35t> <%x> <%X> <%50.50c> %m}{TRACE = magenta}%n]]></Pattern>
            </PatternLayout>
        </Console>
        <List name="Test Appender"/>
    </Appenders>
    <Loggers>
        <Root level="INFO">
            <AppenderRef ref="Console Appender"/>
        </Root>
        <Logger name="net.kautler" level="ALL">
            <AppenderRef ref="Test Appender"/>
        </Logger>
        <Logger name="org.jboss.weld">
            <AppenderRef ref="Test Appender" level="ERROR"/>
        </Logger>
    </Loggers>
</Configuration>
